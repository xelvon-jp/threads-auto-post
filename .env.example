# Threads自動投稿スクリプト用 環境変数テンプレート
# このファイルを .env にコピーして値を埋めてください

# Threads APIユーザーID（数値）
# 取得方法: https://graph.threads.net/v1.0/me?fields=id&access_token=YOUR_TOKEN
THREADS_USER_ID=

# Threads長期アクセストークン（60日有効、自動更新可）
THREADS_ACCESS_TOKEN=

# noteのユーザー名（@マーク不要）
NOTE_USERNAME=xelvon

# 投稿履歴JSONの保存パス（省略可、既定はスクリプトと同じ場所）
# POST_HISTORY_PATH=/path/to/post_history.json
